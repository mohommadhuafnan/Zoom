# Required for Vercel (Production + Preview + Development)
# Also used by the desktop app (copy this file to backend/.env)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your_supabase_secret_key
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
JWT_SECRET=use-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d
NODE_ENV=production
CLIENT_URL=https://zoom-xi-ten.vercel.app

# Desktop only (optional — Electron sets these automatically)
# DESKTOP_MODE=true
# PORT=5123

# Public download link for the Windows installer (required for sharing — Vercel cannot host 100MB files)
# Upload UniMeet-Setup.exe to GitHub Releases, Google Drive, or Supabase Storage, then paste the direct URL:
# APP_DOWNLOAD_URL=https://github.com/YOUR_USER/Zoom/releases/download/v1.0.0/UniMeet-Setup.exe